---
import "../styles/global.css";
import { symbolSVG } from "../assets/svgs/index";

export interface Props {
  title?: string;
}

const { title = "Evento Livre — Manual de Identidade Visual" } = Astro.props;

const sections = [
  { id: "marca", label: "Marca" },
  { id: "simbolo", label: "Símbolo" },
  { id: "cores", label: "Cores" },
  { id: "tipografia", label: "Tipografia" },
  { id: "voz", label: "Voz" },
];
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="Manual de Identidade Visual do Evento Livre — plataforma SaaS de ticketing e gestão de eventos" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts: Schibsted Grotesk + Instrument Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600&family=Schibsted+Grotesk:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Navigation -->
    <nav class="nav">
      <div class="nav-inner">
        <a href="#" class="nav-logo" aria-label="Home">
          <span class="nav-logo-icon" aria-hidden="true" set:html={symbolSVG.replace('<svg', '<svg width="32" height="32"').replace('viewBox="0 0 400 400"', 'viewBox="0 0 400 400"')}></span>
          <span class="nav-logo-text">Evento Livre</span>
        </a>
        <ul class="nav-links">
          {sections.map((s) => (
            <li><a href={`#${s.id}`} class="nav-link">{s.label}</a></li>
          ))}
        </ul>
        <button class="nav-toggle" aria-label="Toggle menu" aria-expanded="false">
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
      </div>
    </nav>

    <!-- Mobile nav overlay -->
    <div class="nav-overlay" aria-hidden="true"></div>

    <!-- Main content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <p>© {new Date().getFullYear()} Evento Livre. Todos os direitos reservados.</p>
        <p>Manual de Identidade Visual — v1.0</p>
      </div>
    </footer>

    <!-- Mobile nav toggle script -->
    <script>
      const toggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
      const overlay = document.querySelector<HTMLElement>(".nav-overlay");
      const links = document.querySelectorAll<HTMLAnchorElement>(".nav-link");
      const navLinks = document.querySelector<HTMLElement>(".nav-links");

      if (toggle && overlay && navLinks) {
        function open() {
          toggle.setAttribute("aria-expanded", "true");
          navLinks.classList.add("open");
          overlay.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
        }
        function close() {
          toggle.setAttribute("aria-expanded", "false");
          navLinks.classList.remove("open");
          overlay.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
        }
        toggle.addEventListener("click", () => {
          const expanded = toggle.getAttribute("aria-expanded") === "true";
          expanded ? close() : open();
        });
        overlay.addEventListener("click", close);
        links.forEach((l) => l.addEventListener("click", close));
        window.addEventListener("resize", () => {
          if (window.innerWidth > 768) close();
        });
      }
    </script>
  </body>
</html>

<style>
  /* ── Navigation ────────────────────────────────────────────── */
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    background: rgba(246, 244, 239, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(147, 160, 174, 0.2);
    z-index: 100;
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--space-6);
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--color-primary);
  }

  .nav-logo-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .nav-logo-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .nav-logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-primary);
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: var(--space-8);
    align-items: center;
  }

  .nav-link {
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-support-2);
    text-decoration: none;
    transition: color var(--transition-fast);
    position: relative;
  }

  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width var(--transition-normal);
  }

  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--color-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
  }

  .nav-toggle-bar {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform var(--transition-fast);
  }

  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(7, 21, 39, 0.5);
    z-index: 99;
  }

  @media (max-width: 768px) {
    .nav-links {
      position: fixed;
      top: var(--nav-height);
      right: 0;
      bottom: 0;
      width: 75%;
      max-width: 320px;
      flex-direction: column;
      padding: var(--space-12) var(--space-6);
      background: var(--color-white);
      gap: var(--space-6);
      align-items: flex-start;
      transform: translateX(100%);
      transition: transform var(--transition-normal);
      box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
    }

    .nav-links.open {
      transform: translateX(0);
    }

    .nav-toggle {
      display: flex;
    }

    .nav-overlay[aria-hidden="false"] {
      display: block;
    }

    .nav-link {
      font-size: 1rem;
    }
  }

  /* ── Footer ────────────────────────────────────────────────── */
  .footer {
    background: var(--color-secondary);
    color: var(--color-support-2);
    padding: var(--space-12) var(--space-6);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer p {
    font-size: 0.8rem;
    margin: 0;
  }
</style>